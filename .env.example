# Canonique prod (TLD .football) — OAuth & métadonnées ; laisser vide en local si tu testes sur localhost
# NEXT_PUBLIC_SITE_URL=https://apex.football

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Même URL que le projet (pour scripts/seed.mjs si tu n’utilises que NEXT_PUBLIC_*)
# SUPABASE_URL=https://xxxx.supabase.co

# Backoffice : clé service (Settings → API) — ne jamais exposer au client
# Utilisée aussi par : npm run seed (charge .env.local via Node 20+)
SUPABASE_SERVICE_ROLE_KEY=

# Admins (accès immédiat au backoffice, séparés par des virgules)
ADMIN_EMAILS=you@example.com

# Chat Grok (optionnel)
# XAI_API_KEY=
# GROK_MODEL=grok-2-latest
