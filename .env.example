# Canonique prod (TLD .football) — OAuth & métadonnées ; laisser vide en local si tu testes sur localhost
# NEXT_PUBLIC_SITE_URL=https://apex.football

# Domaine racine pour sous-domaines pays (ba.apex.world, bosna.apex.world). Défaut : apex.football
# Exemple prod apex.world : NEXT_PUBLIC_APEX_ROOT_DOMAIN=apex.world
# NEXT_PUBLIC_APEX_ROOT_DOMAIN=apex.football

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Même URL que le projet (pour scripts/seed.mjs si tu n’utilises que NEXT_PUBLIC_*)
# SUPABASE_URL=https://xxxx.supabase.co

# Backoffice : clé service (Settings → API) — ne jamais exposer au client
# Utilisée aussi par : npm run seed (charge .env.local via Node 20+)
SUPABASE_SERVICE_ROLE_KEY=

# Admins (accès immédiat au backoffice, séparés par des virgules)
ADMIN_EMAILS=you@example.com

# Chat Grok (optionnel)
# XAI_API_KEY=
# GROK_MODEL=grok-2-latest

# OpenClaw (optionnel, prioritaire sur Grok si la clé est définie)
# OPENCLAW_API_KEY=
# OPENCLAW_MODEL=openclaw-chat
# OPENCLAW_API_URL=https://api.openclaw.ai/v1/chat/completions

# Playlist YouTube / YouTube Music (publique) — lecteur global. ID = paramètre `list` dans l’URL (ex. PLxxxx…)
# Compte source de référence : aldric.laure@gmail.com — coller l’ID depuis Partager sur music.youtube.com
# NEXT_PUBLIC_YOUTUBE_PLAYLIST_ID=PLxxxxxxxxxxxxxxxx

# Instagram @apexfootball.world64 — URLs de posts/reels à afficher en embed dans le panneau global (séparées par des virgules)
# NEXT_PUBLIC_INSTAGRAM_POST_URLS=https://www.instagram.com/p/XXXX/,https://www.instagram.com/reel/YYYY/
